<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BitFab.KW1281Test.Ui.ViewModels.Can"
             x:Class="BitFab.KW1281Test.Ui.Views.Can.ClusterSwapView"
             x:DataType="vm:ClusterSwapViewModel">

  <DockPanel Margin="16">
    <TextBlock DockPanel.Dock="Top" Text="Cluster Swap (EEPROM)" FontSize="20" FontWeight="Bold" Margin="0,0,0,12"/>

    <!-- Status + Progress -->
    <StackPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
      <ProgressBar Value="{Binding Progress}" Maximum="100" Minimum="0" Height="6" Margin="0,0,0,4"/>
      <TextBlock Text="{Binding StatusText}" FontStyle="Italic"
                 Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
    </StackPanel>

    <ScrollViewer>
      <StackPanel Spacing="12">

        <!-- Section 1: Read cluster info -->
        <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                BorderThickness="1" CornerRadius="4" Padding="12">
          <StackPanel Spacing="8">
            <TextBlock Text="1. Cluster Identification" FontWeight="SemiBold" FontSize="14"/>
            <Button Content="Read Cluster Info + SKC" Command="{Binding ReadClusterInfoCommand}"/>
            <TextBlock Text="{Binding ClusterInfo}" FontFamily="Consolas" FontSize="12"
                       TextWrapping="Wrap" IsVisible="{Binding ClusterInfo, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
            <StackPanel Orientation="Horizontal" Spacing="16">
              <TextBlock Text="{Binding SkcInfo}" FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                         Foreground="Orange"
                         IsVisible="{Binding SkcInfo, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
              <TextBlock FontFamily="Consolas" FontSize="13"
                         IsVisible="{Binding ImmoId, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                <Run Text="Immo ID: "/><Run Text="{Binding ImmoId}"/>
              </TextBlock>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- Section 2: Dump EEPROM -->
        <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                BorderThickness="1" CornerRadius="4" Padding="12">
          <StackPanel Spacing="8">
            <TextBlock Text="2. Dump EEPROM (Read)" FontWeight="SemiBold" FontSize="14"/>
            <TextBlock Text="Reads the full 2 KB EEPROM from the cluster and saves to Desktop."
                       TextWrapping="Wrap" FontSize="12"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
            <Button Content="Dump Full EEPROM (2 KB)" Command="{Binding DumpEepromCommand}" Classes="accent"/>
            <TextBlock Text="{Binding SavePath}" FontFamily="Consolas" FontSize="11"
                       TextWrapping="Wrap" Foreground="Green"
                       IsVisible="{Binding SavePath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
          </StackPanel>
        </Border>

        <!-- Section 3: Load dump file -->
        <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                BorderThickness="1" CornerRadius="4" Padding="12">
          <StackPanel Spacing="8">
            <TextBlock Text="3. Load Dump File (for Write)" FontWeight="SemiBold" FontSize="14"/>
            <TextBlock Text="Load a previously saved .bin dump from the OLD cluster."
                       TextWrapping="Wrap" FontSize="12"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBox Text="{Binding LoadPath}" Watermark="Path to .bin file..." Width="400"/>
              <Button Content="Load" Command="{Binding LoadDumpCommand}"/>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- Section 4: Write -->
        <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                BorderThickness="1" CornerRadius="4" Padding="12">
          <StackPanel Spacing="8">
            <TextBlock Text="4. Write to Cluster" FontWeight="SemiBold" FontSize="14"/>
            <TextBlock TextWrapping="Wrap" FontSize="12"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}">
              <Run Text="Write loaded dump data to the NEW cluster. "/>
              <Run Text="'Write Immo Region' copies only the SKC + Immo ID + key data (safest for swap)." FontWeight="SemiBold"/>
            </TextBlock>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Content="Write Immo Region Only" Command="{Binding WriteImmoRegionCommand}" Classes="accent"/>
              <Button Content="Write Full EEPROM" Command="{Binding WriteEepromCommand}"/>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- Hex dump display -->
        <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                BorderThickness="1" CornerRadius="4" Padding="12"
                IsVisible="{Binding DumpHex, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
          <StackPanel Spacing="4">
            <TextBlock Text="Immo Region Hex Dump (0x0090 - 0x010C)" FontWeight="SemiBold" FontSize="14"/>
            <TextBlock Text="{Binding DumpHex}" FontFamily="Consolas" FontSize="11"
                       TextWrapping="NoWrap"/>
          </StackPanel>
        </Border>

      </StackPanel>
    </ScrollViewer>
  </DockPanel>

</UserControl>
