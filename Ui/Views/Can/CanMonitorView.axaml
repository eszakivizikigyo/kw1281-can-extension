<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BitFab.KW1281Test.Ui.ViewModels.Can"
             x:Class="BitFab.KW1281Test.Ui.Views.Can.CanMonitorView"
             x:DataType="vm:CanMonitorViewModel">

    <DockPanel Margin="16">
        <TextBlock DockPanel.Dock="Top" Text="CAN Bus Monitor" FontSize="20" FontWeight="Bold" Margin="0,0,0,12" />

        <StackPanel DockPanel.Dock="Top" Spacing="8" MaxWidth="600" HorizontalAlignment="Left">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Start Monitoring" Command="{Binding StartCommand}" Classes="accent" />
                <Button Content="Stop" Command="{Binding StopCommand}" />
                <TextBlock Text="{Binding MessageCount, StringFormat='Messages: {0}'}"
                           VerticalAlignment="Center" />
            </StackPanel>

            <TextBlock Text="{Binding StatusText}" FontStyle="Italic"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />

            <TextBlock Text="CAN traffic appears in the Communication Log below."
                       TextWrapping="Wrap" Margin="0,8,0,0"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
        </StackPanel>
    </DockPanel>

</UserControl>
