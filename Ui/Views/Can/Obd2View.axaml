<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BitFab.KW1281Test.Ui.ViewModels.Can"
             x:Class="BitFab.KW1281Test.Ui.Views.Can.Obd2View"
             x:DataType="vm:Obd2ViewModel">

  <DockPanel Margin="16">
    <TextBlock DockPanel.Dock="Top" Text="OBD2 Live Data" FontSize="20" FontWeight="Bold" Margin="0,0,0,12"/>

    <!-- Action buttons -->
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
      <TextBlock Text="Target:" VerticalAlignment="Center"/>
      <ComboBox ItemsSource="{Binding AvailableTargets}" SelectedItem="{Binding SelectedTarget}" Width="130"/>
      <Separator Width="1" Margin="4,0"/>
      <Button Content="Detect PIDs" Command="{Binding DetectPidsCommand}"/>
      <Button Content="Query Once" Command="{Binding QueryOnceCommand}"/>
      <Button Content="▶ Live" Command="{Binding StartLiveCommand}" Classes="accent"/>
      <Button Content="■ Stop" Command="{Binding StopCommand}"/>
      <Separator Width="1" Margin="4,0"/>
      <TextBlock Text="Interval (ms):" VerticalAlignment="Center"/>
      <NumericUpDown Value="{Binding RefreshIntervalMs}" Minimum="100" Maximum="5000" Increment="100"
                     FormatString="0" Width="100"/>
    </StackPanel>

    <!-- DTC row -->
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
      <Button Content="Read DTC" Command="{Binding ReadDtcCommand}"/>
      <Button Content="Clear DTC" Command="{Binding ClearDtcCommand}"/>
      <ItemsControl ItemsSource="{Binding DtcList}" Margin="8,0,0,0">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <StackPanel Orientation="Horizontal" Spacing="8"/>
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Background="{DynamicResource SystemControlBackgroundListLowBrush}"
                    CornerRadius="4" Padding="6,2">
              <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="12"/>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>

    <!-- Status bar -->
    <TextBlock DockPanel.Dock="Bottom" Text="{Binding StatusText}" Margin="0,8,0,0"
               FontStyle="Italic" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>

    <!-- PID DataGrid -->
    <DataGrid ItemsSource="{Binding Pids}"
              IsReadOnly="False"
              AutoGenerateColumns="False"
              GridLinesVisibility="Horizontal"
              BorderThickness="1"
              BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
              CanUserSortColumns="True">
      <DataGrid.Columns>
        <DataGridCheckBoxColumn Header="✓" Width="40"
                                 Binding="{Binding IsSelected}"/>
        <DataGridTextColumn Header="PID" Width="60" IsReadOnly="True"
                             Binding="{Binding PidHex}"/>
        <DataGridTextColumn Header="Name" Width="180" IsReadOnly="True"
                             Binding="{Binding Name}"/>
        <DataGridTextColumn Header="Value" Width="140" IsReadOnly="True"
                             Binding="{Binding FormattedValue}"/>
        <DataGridTextColumn Header="Raw" Width="80" IsReadOnly="True"
                             Binding="{Binding RawHex}"/>
        <DataGridTextColumn Header="Unit" Width="60" IsReadOnly="True"
                             Binding="{Binding Unit}"/>
      </DataGrid.Columns>
    </DataGrid>
  </DockPanel>

</UserControl>
