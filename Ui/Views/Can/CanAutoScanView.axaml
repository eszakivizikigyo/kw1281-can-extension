<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BitFab.KW1281Test.Ui.ViewModels.Can"
             x:Class="BitFab.KW1281Test.Ui.Views.Can.CanAutoScanView"
             x:DataType="vm:CanAutoScanViewModel">

    <DockPanel Margin="16">
        <TextBlock DockPanel.Dock="Top" Text="CAN Auto Scan" FontSize="20" FontWeight="Bold" Margin="0,0,0,12" />

        <StackPanel DockPanel.Dock="Top" Spacing="8" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Start Scan" Command="{Binding StartCommand}" Classes="accent" />
                <Button Content="Stop" Command="{Binding StopCommand}" />
                <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" FontStyle="Italic"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
            </StackPanel>

            <ProgressBar Value="{Binding Progress}" Maximum="127" Minimum="0" Height="8" />
        </StackPanel>

        <DataGrid ItemsSource="{Binding Results}"
                  IsReadOnly="True"
                  AutoGenerateColumns="False"
                  GridLinesVisibility="Horizontal"
                  BorderThickness="1"
                  BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Address" Width="80"
                                     Binding="{Binding Address}" />
                <DataGridTextColumn Header="Name" Width="160"
                                     Binding="{Binding Name}" />
                <DataGridTextColumn Header="Protocol" Width="100"
                                     Binding="{Binding Protocol}" />
                <DataGridTextColumn Header="Identification" Width="*"
                                     Binding="{Binding Identification}" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>

</UserControl>
