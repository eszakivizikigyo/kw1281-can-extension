<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BitFab.KW1281Test.Ui.ViewModels.Shared"
             x:Class="BitFab.KW1281Test.Ui.Views.Shared.HexEditorView"
             x:DataType="vm:HexEditorViewModel">

  <DockPanel>
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,4">
      <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" FontStyle="Italic"
                 Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
      <Button Content="Clear" Command="{Binding ClearCommand}" Padding="8,2" />
    </StackPanel>

    <!-- Header -->
    <Grid DockPanel.Dock="Top" Margin="0,0,0,2">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="85" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="140" />
      </Grid.ColumnDefinitions>
      <TextBlock Grid.Column="0" Text="Address" FontWeight="SemiBold" FontFamily="Cascadia Mono, Consolas, monospace" FontSize="12" />
      <TextBlock Grid.Column="1" Text="00 01 02 03 04 05 06 07  08 09 0A 0B 0C 0D 0E 0F"
                 FontWeight="SemiBold" FontFamily="Cascadia Mono, Consolas, monospace" FontSize="12" />
      <TextBlock Grid.Column="2" Text="ASCII" FontWeight="SemiBold" FontFamily="Cascadia Mono, Consolas, monospace" FontSize="12" />
    </Grid>

    <ListBox ItemsSource="{Binding Rows}"
             FontFamily="Cascadia Mono, Consolas, Courier New, monospace"
             FontSize="12"
             Background="Transparent">
      <ListBox.ItemTemplate>
        <DataTemplate x:DataType="vm:HexRow">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="85" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="140" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{Binding AddressText}" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
            <TextBlock Grid.Column="1" Text="{Binding HexText}" />
            <TextBlock Grid.Column="2" Text="{Binding AsciiText}" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
          </Grid>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
  </DockPanel>
</UserControl>
