<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BitFab.KW1281Test.Ui.ViewModels.KLine"
             x:Class="BitFab.KW1281Test.Ui.Views.KLine.ClusterView"
             x:DataType="vm:ClusterViewModel">

    <DockPanel Margin="16">
        <TextBlock DockPanel.Dock="Top" Text="Cluster Operations" FontSize="20" FontWeight="Bold" Margin="0,0,0,12" />

        <StackPanel DockPanel.Dock="Top" Spacing="8" MaxWidth="500" HorizontalAlignment="Left">
            <TextBlock Text="Cluster-specific functions (address 0x17)."
                       TextWrapping="Wrap" Margin="0,0,0,8"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />

            <WrapPanel Orientation="Horizontal">
                <Button Content="Get SKC" Command="{Binding GetSkcCommand}" Classes="accent" Margin="0,0,8,8" />
                <Button Content="Get Cluster ID" Command="{Binding GetClusterIdCommand}" Margin="0,0,8,8" />
                <Button Content="Software Version" Command="{Binding ReadSoftwareVersionCommand}" Margin="0,0,8,8" />
                <Button Content="Toggle RB4 Mode" Command="{Binding ToggleRB4ModeCommand}" Margin="0,0,8,8" />
                <Button Content="Reset Cluster" Command="{Binding ResetCommand}" Margin="0,0,8,8" />
            </WrapPanel>

            <TextBlock Text="{Binding StatusText}" FontStyle="Italic" Margin="0,8,0,0"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
        </StackPanel>
    </DockPanel>

</UserControl>
