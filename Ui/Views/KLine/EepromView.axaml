<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BitFab.KW1281Test.Ui.ViewModels.KLine"
             x:Class="BitFab.KW1281Test.Ui.Views.KLine.EepromView"
             x:DataType="vm:EepromViewModel">

    <DockPanel Margin="16">
        <TextBlock DockPanel.Dock="Top" Text="EEPROM" FontSize="20" FontWeight="Bold" Margin="0,0,0,12" />

        <StackPanel DockPanel.Dock="Top" Spacing="8" MaxWidth="500" HorizontalAlignment="Left">
            <!-- Address -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Address:" VerticalAlignment="Center" Width="80" />
                <NumericUpDown Value="{Binding Address}" Minimum="0" Maximum="65535"
                               FormatString="0" MinWidth="120" />
            </StackPanel>

            <!-- Single Read/Write -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Read" Command="{Binding ReadCommand}" />
                <TextBlock Text="Value:" VerticalAlignment="Center" />
                <NumericUpDown Value="{Binding WriteValue}" Minimum="0" Maximum="255"
                               FormatString="0" MinWidth="80" />
                <Button Content="Write" Command="{Binding WriteCommand}" />
            </StackPanel>

            <Separator Margin="0,8" />

            <!-- Dump -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Length:" VerticalAlignment="Center" Width="80" />
                <NumericUpDown Value="{Binding Length}" Minimum="1" Maximum="65535"
                               FormatString="0" MinWidth="120" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Filename:" VerticalAlignment="Center" Width="80" />
                <TextBox Text="{Binding Filename}" MinWidth="200" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                <Button Content="Dump" Command="{Binding DumpCommand}" Classes="accent" />
                <Button Content="Map" Command="{Binding MapCommand}" />
            </StackPanel>

            <!-- Status -->
            <TextBlock Text="{Binding StatusText}" FontStyle="Italic" Margin="0,8,0,0"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
        </StackPanel>
    </DockPanel>

</UserControl>
