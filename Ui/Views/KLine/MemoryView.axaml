<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BitFab.KW1281Test.Ui.ViewModels.KLine"
             x:Class="BitFab.KW1281Test.Ui.Views.KLine.MemoryView"
             x:DataType="vm:MemoryViewModel">

    <DockPanel Margin="16">
        <TextBlock DockPanel.Dock="Top" Text="Memory (RAM/ROM)" FontSize="20" FontWeight="Bold" Margin="0,0,0,12" />

        <StackPanel DockPanel.Dock="Top" Spacing="8" MaxWidth="500" HorizontalAlignment="Left">
            <!-- Memory Type -->
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,4">
                <RadioButton Content="RAM" IsChecked="{Binding IsRam}" GroupName="MemType" />
                <RadioButton Content="ROM" IsChecked="{Binding IsRom}" GroupName="MemType" />
            </StackPanel>

            <!-- Address -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Address:" VerticalAlignment="Center" Width="80" />
                <NumericUpDown Value="{Binding Address}" Minimum="0" Maximum="65535"
                               FormatString="0" MinWidth="120" />
            </StackPanel>

            <Button Content="Read Single" Command="{Binding ReadCommand}" />

            <Separator Margin="0,8" />

            <!-- Dump -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Length:" VerticalAlignment="Center" Width="80" />
                <NumericUpDown Value="{Binding Length}" Minimum="1" Maximum="65535"
                               FormatString="0" MinWidth="120" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Filename:" VerticalAlignment="Center" Width="80" />
                <TextBox Text="{Binding Filename}" MinWidth="200" />
            </StackPanel>

            <Button Content="Dump" Command="{Binding DumpCommand}" Classes="accent" Margin="0,4,0,0" />

            <!-- Status -->
            <TextBlock Text="{Binding StatusText}" FontStyle="Italic" Margin="0,8,0,0"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
        </StackPanel>
    </DockPanel>

</UserControl>
